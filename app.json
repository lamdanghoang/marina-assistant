{
  "expo": {
    "name": "Marina Assistant",
    "slug": "marina-assistant",
    "scheme": "marina-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1617"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marina.assistant",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Marina needs speech recognition to process your voice commands.",
        "NSMicrophoneUsageDescription": "Marina needs microphone access for voice commands.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "marina-ai"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1617"
      },
      "package": "com.marina.assistant",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Marina needs microphone access for voice commands."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49793e93-51f4-4897-a1bc-13fc5e6fa579"
      }
    }
  }
}
